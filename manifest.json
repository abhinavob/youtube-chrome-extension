{
  "manifest_version": 3,
  "name": "VidAssist",
  "version": "1.0",
  "description": "Allows extended playback speed control for videos on any site, shows total watch time of YouTube playlists, and speeds up YouTube ads.",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["playlist.js"]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["playback.js"]
    }
  ],
  "commands": {
    "speed-up": {
      "suggested_key": {
        "default": "Alt+Shift+Period"
      },
      "description": "Increase playback speed"
    },
    "speed-down": {
      "suggested_key": {
        "default": "Alt+Shift+Comma"
      },
      "description": "Decrease playback speed"
    },
    "speed-normal": {
      "suggested_key": {
        "default": "Alt+Shift+K"
      },
      "description": "Set playback speed to normal"
    },
    "speed-max": {
      "suggested_key": {
        "default": "Alt+Shift+L"
      },
      "description": "Set playback speed to maximum"
    }
  },
  "action": {
    "default_popup": "popup.html"
  }
}